# Copia este archivo a Pipeline/.env y rellena solo los valores necesarios.
# No subas Pipeline/.env al repositorio.

GEMINI_API_KEY=
GEMINI_PROGRESS=true

GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-3.5-flash,gemini-2.5-flash,gemini-2.5-flash-lite

GEMINI_RETRY_MODEL=gemini-3.5-flash
GEMINI_RETRY_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash

GEMINI_MODEL_RPM_LIMITS=gemini-3.5-flash:2,gemini-3.1-flash-lite:10,gemini-2.5-flash:3,gemini-2.5-flash-lite:8

# Opcionales: deja estas lineas comentadas si no necesitas cambiar los valores por defecto.
# SOCCERDATA_DIR=C:/Users/Usuario/soccerdata
# GEMINI_MAX_LIVE_CALLS=
# GEMINI_TIMEOUT_SECONDS=60
# GEMINI_RETRY_ATTEMPTS=2
# GEMINI_RETRY_BASE_SECONDS=10
# GEMINI_MIN_SECONDS_BETWEEN_CALLS=0
#
# GRAPHDB_BASE_URL=http://localhost:7200
# GRAPHDB_REPOSITORY_ID=TFG_SoccerData
# GRAPHDB_TTL_FILENAME=full_knowledge_graph.ttl
# GRAPHDB_CONNECT_TIMEOUT_SECONDS=30
# GRAPHDB_READ_TIMEOUT_SECONDS=0
# GRAPHDB_USERNAME=
# GRAPHDB_PASSWORD=
# GRAPHDB_CONTEXT_GRAPH_URI=
